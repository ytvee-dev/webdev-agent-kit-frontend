---
import CalciferGraph from './CalciferGraph.astro'

const stack = ['React', 'Next.js', 'TypeScript', 'CSS Modules', 'Redux', 'TanStack', 'Axios', 'Codex', 'Claude']
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero__ambient" aria-hidden="true"></div>
  <div class="hero__visual">
    <CalciferGraph />
  </div>

  <div class="hero__container">
    <div class="hero__copy">
      <p class="hero__eyebrow">Project-local operating kit</p>

      <h1 id="hero-title">Make frontend coding agents safer to use.</h1>

      <p class="hero__description">
        WebDev Agent Kit helps AI coding agents plan, implement, debug, refactor, review and visually
        verify frontend work without broad rewrites, unapproved packages, fake verification or generic
        UI output.
      </p>

      <div class="hero__actions" aria-label="Project links">
        <a
          class="button button--primary"
          href="https://github.com/ytvee-dev/webdev-agent-kit/releases/latest"
        >
          Download latest release
        </a>
        <a class="button button--secondary" href="https://github.com/ytvee-dev/webdev-agent-kit#readme">
          Read the docs
        </a>
        <a class="button button--ghost" href="https://github.com/ytvee-dev/webdev-agent-kit">
          View on GitHub
        </a>
      </div>

      <ul class="hero__stack" aria-label="Supported tools and technologies">
        {stack.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </div>
</section>

<style>
  .hero {
    --torch-x: 66%;
    --torch-y: 50%;
    --torch-radius: 220px;
    --torch-intensity: 0;
    position: relative;
    display: grid;
    min-height: 100svh;
    overflow: clip;
    align-items: center;
    padding: clamp(76px, 8vw, 118px) 24px;
    background:
      radial-gradient(circle at 72% 52%, rgba(70, 13, 4, 0.18), transparent 34%),
      linear-gradient(105deg, #050505 0%, #050505 38%, #020202 100%);
  }

  .hero__ambient {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 68% 50%, rgba(255, 74, 13, 0.09), transparent 24%),
      radial-gradient(circle at 73% 45%, rgba(255, 184, 59, 0.035), transparent 36%),
      linear-gradient(90deg, rgba(0, 0, 0, 0.38), transparent 56%);
  }

  .hero__visual {
    position: absolute;
    inset: 0;
    z-index: 1;
    min-width: 0;
  }

  .hero__container {
    position: relative;
    z-index: 3;
    width: min(1180px, 100%);
    margin: 0 auto;
    pointer-events: none;
  }

  .hero__copy {
    position: relative;
    display: flex;
    width: min(540px, 100%);
    min-width: 0;
    flex-direction: column;
    align-items: flex-start;
    pointer-events: auto;
  }

  .hero__copy::before {
    position: absolute;
    inset: -74px -96px;
    z-index: -1;
    content: '';
    pointer-events: none;
    background: radial-gradient(ellipse at 36% 48%, rgba(3, 3, 3, 0.98) 0%, rgba(3, 3, 3, 0.86) 42%, transparent 74%);
    filter: blur(14px);
  }

  .hero__eyebrow {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    padding: 5px 12px;
    margin: 0 0 26px;
    border: 1px solid rgba(255, 183, 70, 0.22);
    border-radius: 999px;
    background: rgba(255, 143, 35, 0.075);
    color: #ffc565;
    font-size: 13px;
    font-weight: 650;
    letter-spacing: 0.01em;
  }

  h1 {
    max-width: 570px;
    margin: 0;
    font-size: clamp(48px, 5.45vw, 74px);
    font-weight: 720;
    letter-spacing: -0.055em;
    line-height: 0.99;
    text-wrap: balance;
  }

  .hero__description {
    max-width: 560px;
    margin: 30px 0 0;
    color: var(--text-secondary);
    font-size: clamp(17px, 1.4vw, 20px);
    line-height: 1.62;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 36px;
  }

  .button {
    display: inline-flex;
    min-height: 46px;
    align-items: center;
    justify-content: center;
    padding: 0 19px;
    border: 1px solid transparent;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 680;
    line-height: 1;
    text-decoration: none;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background-color 160ms ease,
      color 160ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .button:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--focus), transparent 46%);
    outline-offset: 3px;
  }

  .button--primary {
    background: linear-gradient(135deg, #ffd264, #ff8a26);
    box-shadow: 0 12px 34px rgba(255, 119, 25, 0.22);
    color: #171008;
  }

  .button--primary:hover {
    background: linear-gradient(135deg, #ffdc80, #ff9c3d);
  }

  .button--secondary {
    border-color: rgba(255, 230, 193, 0.2);
    background: rgba(255, 255, 255, 0.055);
    color: var(--text-primary);
  }

  .button--secondary:hover {
    border-color: rgba(255, 198, 104, 0.42);
    background: rgba(255, 180, 66, 0.09);
  }

  .button--ghost {
    color: var(--text-secondary);
  }

  .button--ghost:hover {
    color: #ffd183;
  }

  .hero__stack {
    display: flex;
    max-width: 500px;
    flex-wrap: wrap;
    gap: 8px;
    padding: 0;
    margin: 28px 0 0;
    list-style: none;
  }

  .hero__stack li {
    display: inline-flex;
    min-height: 29px;
    align-items: center;
    padding: 4px 11px;
    border: 1px solid rgba(255, 236, 207, 0.11);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.026);
    color: var(--text-muted);
    font-size: 12px;
    font-weight: 560;
  }

  @media (max-width: 1040px) {
    .hero {
      min-height: 1120px;
      align-items: start;
      padding-top: 72px;
    }

    .hero__copy {
      width: min(680px, 100%);
    }

    h1,
    .hero__description {
      max-width: 650px;
    }

    .hero__copy::before {
      inset: -54px -68px;
    }
  }

  @media (max-width: 620px) {
    .hero {
      min-height: 1120px;
      padding: 54px 18px 500px;
    }

    .hero__copy::before {
      inset: -38px -26px;
      background: radial-gradient(ellipse at 34% 36%, rgba(3, 3, 3, 0.99) 0%, rgba(3, 3, 3, 0.9) 58%, transparent 90%);
    }

    .hero__eyebrow {
      margin-bottom: 22px;
    }

    h1 {
      font-size: clamp(42px, 13.5vw, 58px);
    }

    .hero__description {
      margin-top: 24px;
      font-size: 17px;
    }

    .hero__actions {
      width: 100%;
      margin-top: 30px;
    }

    .button--primary,
    .button--secondary {
      flex: 1 1 auto;
    }

    .button--ghost {
      flex-basis: 100%;
      justify-content: flex-start;
      padding-left: 4px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .button {
      transition: none;
    }

    .button:hover {
      transform: none;
    }
  }
</style>
