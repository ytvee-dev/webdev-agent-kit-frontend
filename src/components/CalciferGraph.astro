---
import { createCalciferGraph } from '../scripts/graph/generateGraph'

const fallbackGraph = createCalciferGraph({ nodeCount: 180, seed: 20260710 })
const toColor = (color: readonly [number, number, number]): string =>
  `rgb(${Math.round(color[0] * 255)} ${Math.round(color[1] * 255)} ${Math.round(color[2] * 255)})`

const codeSources = [
  `type AgentTask = {
  scope: "frontend"
  evidence: Verification[]
  approvalRequired: boolean
}

const workflow = async (task: AgentTask) => {
  const context = await inspectProject(task.scope)
  const plan = createSmallestSafePlan(context)
  const result = await executeApprovedScope(plan)
  return verifyWithEvidence(result)
}

export const guardrails = {
  broadRewrites: false,
  unapprovedPackages: false,
  fakeVerification: false,
}`,
  `interface ProjectContext {
  framework: "astro" | "react" | "next"
  styling: "css-modules" | "scoped-css"
  packageManager: "npm"
  constraints: string[]
}

export const inspectProject = async () => {
  const files = await readRelevantFiles()
  const patterns = inferExistingPatterns(files)
  const risks = identifyChangeRisks(patterns)
  return { files, patterns, risks }
}

const scope = selectMinimumFiles({
  requestedChange,
  dependencies,
  existingComponents,
})`,
  `const implementation = defineWorkflow({
  classify: classifyPrompt,
  inspect: inspectExistingCode,
  plan: createMilestones,
  execute: implementApprovedScope,
  review: selfReviewChanges,
  verify: collectEvidence,
})

const report = {
  changed: changedFiles,
  why: implementationReason,
  verified: verificationEvidence,
  risks: remainingRisks,
}

if (requiresNewPackage(report)) {
  await requestApproval()
}

return formatCompactResult(report)`,
  `export const visualVerification = async () => {
  const desktop = await captureViewport(1440, 900)
  const tablet = await captureViewport(1024, 768)
  const mobile = await captureViewport(390, 844)

  return compareAgainstIntent({
    desktop,
    tablet,
    mobile,
    checks: [
      "layout",
      "overflow",
      "contrast",
      "interaction",
    ],
  })
}

const result = await runExistingChecks()
assertEvidence(result)`,
  `type ChangeDecision =
  | { kind: "reuse"; source: string }
  | { kind: "extend"; source: string }
  | { kind: "create"; reason: string }

const decision = await chooseImplementation({
  existingCode,
  approvedScope,
  projectConventions,
})

const patch = await applyDecision(decision)
const review = await inspectDiff(patch)

return {
  patch,
  review,
  verified: review.isSafe,
}`,
  `const release = await prepareRelease({
  branch: "feat/reference-matched-fire-demon",
  target: "main",
  checks: [
    "types",
    "tests",
    "production-build",
  ],
})

const pullRequest = await openPullRequest({
  title: release.title,
  summary: release.summary,
  evidence: release.evidence,
  risks: release.risks,
})

export default pullRequest`,
]

const codeColumns = Array.from({ length: 12 }, (_, index) => codeSources[index % codeSources.length])
---

<calcifer-graph class="graph" data-ready="false" data-dragging="false" data-failed="false">
  <div class="code-field code-field--ambient" aria-hidden="true">
    {codeColumns.map((column) => <pre><code>{column}</code></pre>)}
  </div>

  <div class="code-field code-field--lit" aria-hidden="true">
    {codeColumns.map((column) => <pre><code>{column}</code></pre>)}
  </div>

  <svg
    class="fallback"
    viewBox="-1.82 -1.64 3.64 3.34"
    preserveAspectRatio="xMidYMid meet"
    role="img"
    aria-label="A smiling fire demon formed from connected graph nodes"
  >
    <g transform="scale(1 -1)">
      {fallbackGraph.edges.slice(0, 2200).map((edge) => {
        const source = fallbackGraph.nodes[edge.source]
        const target = fallbackGraph.nodes[edge.target]

        if (!source || !target) {
          return null
        }

        return (
          <line
            x1={source.x}
            y1={source.y}
            x2={target.x}
            y2={target.y}
            stroke={toColor(source.color)}
            stroke-opacity={source.role === 'pupil' ? '0.035' : '0.28'}
            stroke-width="0.0042"
          />
        )
      })}
      {fallbackGraph.nodes.map((node) => (
        <circle
          cx={node.x}
          cy={node.y}
          r={node.size / 760}
          fill={toColor(node.color)}
          fill-opacity={node.role === 'pupil' ? '1' : '0.97'}
        />
      ))}
    </g>
  </svg>

  <canvas class="canvas" aria-hidden="true"></canvas>
  <span class="sr-only">
    The graph is decorative. Drag a visible node to stretch the connected fire demon across the section
    and reveal the code hidden in the darkness behind it.
  </span>
</calcifer-graph>

<script>
  class CalciferGraphElement extends HTMLElement {
    private cleanup?: () => void
    private loadPromise?: Promise<void>
    private idleId?: number
    private timeoutId?: ReturnType<typeof globalThis.setTimeout>

    connectedCallback(): void {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        this.dataset.motion = 'reduced'
        return
      }

      const loadImmediately = (): void => {
        void this.load()
      }

      this.addEventListener('pointerenter', loadImmediately, { once: true })
      this.addEventListener('pointerdown', loadImmediately, { once: true })

      const idleWindow = window as Window & {
        requestIdleCallback?: (callback: IdleRequestCallback, options?: IdleRequestOptions) => number
      }

      if (typeof idleWindow.requestIdleCallback === 'function') {
        this.idleId = idleWindow.requestIdleCallback(() => void this.load(), { timeout: 1250 })
      } else {
        this.timeoutId = globalThis.setTimeout(() => void this.load(), 680)
      }
    }

    disconnectedCallback(): void {
      this.cleanup?.()

      const idleWindow = window as Window & {
        cancelIdleCallback?: (handle: number) => void
      }

      if (this.idleId !== undefined && typeof idleWindow.cancelIdleCallback === 'function') {
        idleWindow.cancelIdleCallback(this.idleId)
      }

      if (this.timeoutId !== undefined) {
        window.clearTimeout(this.timeoutId)
      }
    }

    private load(): Promise<void> {
      if (this.loadPromise) {
        return this.loadPromise
      }

      this.loadPromise = import('../scripts/graph/mountCalciferGraph')
        .then(({ mountCalciferGraph }) => {
          const canvas = this.querySelector('canvas')

          if (!(canvas instanceof HTMLCanvasElement) || !canvas.getContext) {
            this.dataset.failed = 'true'
            return
          }

          this.cleanup = mountCalciferGraph(this, canvas)
        })
        .catch(() => {
          this.dataset.failed = 'true'
          this.dataset.ready = 'false'
        })

      return this.loadPromise
    }
  }

  if (!customElements.get('calcifer-graph')) {
    customElements.define('calcifer-graph', CalciferGraphElement)
  }
</script>

<style>
  .graph {
    --torch-x: 66%;
    --torch-y: 50%;
    --torch-radius: 190px;
    --torch-intensity: 0;
    --torch-warmth: 0;
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    min-height: 100svh;
    overflow: hidden;
    isolation: isolate;
    contain: layout paint style;
    touch-action: none;
  }

  .graph::before,
  .graph::after {
    position: absolute;
    inset: -12%;
    z-index: 0;
    content: '';
    pointer-events: none;
  }

  .graph::before {
    background:
      radial-gradient(circle at 68% 54%, rgba(255, 78, 12, 0.18), transparent 22%),
      radial-gradient(circle at 70% 44%, rgba(255, 188, 60, 0.075), transparent 34%),
      radial-gradient(circle at 82% 18%, rgba(114, 16, 80, 0.09), transparent 24%);
    filter: blur(42px);
    opacity: 0.92;
  }

  .graph::after {
    background:
      radial-gradient(
        circle var(--torch-radius) at var(--torch-x) var(--torch-y),
        rgba(255, 190, 85, calc(var(--torch-intensity) * 0.15)),
        rgba(255, 72, 15, calc(var(--torch-intensity) * 0.075)) 42%,
        transparent 78%
      ),
      url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.42'/%3E%3C/svg%3E");
    mix-blend-mode: screen, soft-light;
    opacity: calc(0.08 + var(--torch-warmth) * 0.28);
    transition: opacity 420ms ease;
  }

  .canvas,
  .fallback,
  .code-field {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .canvas {
    z-index: 4;
    display: block;
    opacity: 0;
    transition: opacity 560ms ease;
  }

  .fallback {
    z-index: 3;
    box-sizing: border-box;
    padding: clamp(28px, 4.5vw, 78px);
    filter:
      drop-shadow(0 0 12px rgba(255, 66, 8, 0.38))
      drop-shadow(0 0 48px rgba(255, 88, 16, 0.2));
    opacity: 1;
    transform: translateX(clamp(96px, 17vw, 310px)) scale(0.96);
    transition: opacity 460ms ease;
  }

  .code-field {
    z-index: 1;
    display: grid;
    box-sizing: border-box;
    grid-template-columns: repeat(12, minmax(92px, 1fr));
    gap: clamp(14px, 1.9vw, 34px);
    padding: 1.4vh 1.1vw;
    overflow: hidden;
    color: rgba(255, 220, 168, 0.72);
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    pointer-events: none;
    transform: rotate(-0.65deg) scale(1.035);
    transform-origin: center;
  }

  .code-field pre {
    min-width: 0;
    margin: 0;
    font: inherit;
    font-size: clamp(5px, 0.37vw, 7px);
    line-height: 1.68;
    letter-spacing: -0.035em;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .code-field--ambient {
    opacity: 0.019;
    filter: blur(0.22px);
  }

  .code-field--lit {
    z-index: 2;
    opacity: var(--torch-intensity);
    filter:
      drop-shadow(0 0 7px rgba(255, 142, 48, 0.38))
      drop-shadow(0 0 20px rgba(255, 72, 14, 0.16));
    mask-image: radial-gradient(
      circle var(--torch-radius) at var(--torch-x) var(--torch-y),
      #000 0,
      rgba(0, 0, 0, 0.98) 24%,
      rgba(0, 0, 0, 0.62) 58%,
      rgba(0, 0, 0, 0.18) 78%,
      transparent 100%
    );
    transition: opacity 460ms ease;
  }

  .graph[data-ready='true'] .canvas {
    opacity: 1;
  }

  .graph[data-ready='true'] .fallback {
    opacity: 0;
  }

  .graph[data-failed='true'] .fallback,
  .graph[data-motion='reduced'] .fallback {
    opacity: 1;
  }

  @media (max-width: 1040px) {
    .fallback {
      padding: 170px 32px 26px;
      transform: translateY(180px) scale(0.92);
    }

    .code-field {
      grid-template-columns: repeat(8, minmax(90px, 1fr));
      gap: 18px;
      padding: 1.5vh 1.4vw;
    }
  }

  @media (max-width: 620px) {
    .graph {
      min-height: 1120px;
    }

    .fallback {
      padding: 570px 12px 32px;
      transform: translateY(116px) scale(1.03);
    }

    .code-field {
      grid-template-columns: repeat(6, minmax(74px, 1fr));
      gap: 12px;
      padding: 8px;
    }

    .code-field pre {
      font-size: 5px;
      line-height: 1.58;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .canvas,
    .fallback,
    .code-field,
    .graph::after {
      transition: none;
    }
  }
</style>
